# autotune environment variables
#
# Quick start: run  ./setup.sh  and it will generate this file for you.
# Manual setup: copy to .env and fill in your values.  Never commit .env.

# ── Dashboard & admin API ─────────────────────────────────────────────────────
# Protects the /dashboard UI and all /admin/* endpoints with a password.
# Generate a strong key:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# AUTOTUNE_ADMIN_KEY=your-strong-secret-key-here

# ── API key enforcement ───────────────────────────────────────────────────────
# Set to 1 to require a valid API key on every /v1/* inference request.
# Recommended for team deployments.  0 = open access (personal use only).
# AUTOTUNE_REQUIRE_API_KEY=1

# ── Server port ───────────────────────────────────────────────────────────────
# AUTOTUNE_PORT=8765

# ── Custom Ollama URL (for Docker or remote Ollama) ───────────────────────────
# AUTOTUNE_OLLAMA_URL=http://ollama:11434

# ── Optional: point telemetry at your own Supabase project ────────────────────
# By default autotune uses the built-in anon key (INSERT-only, RLS-protected).
# Set these only if you want to self-host telemetry.
# AUTOTUNE_SUPABASE_URL=https://your-project-ref.supabase.co
# AUTOTUNE_SUPABASE_KEY=your-anon-key

# ── Schema management (maintainers only) ─────────────────────────────────────
# Personal access token for the Supabase Management API.
# Only needed to run scripts/create_supabase_schema.py.
# SUPABASE_PAT=sbp_xxxxxxxxxxxxxxxxxxxx

# ── Privacy defaults ──────────────────────────────────────────────────────────
# 0 = prompts/completions are never written to local SQLite (default, recommended)
# 1 = enable conversation history in the Conversations dashboard tab
# AUTOTUNE_LOG_PROMPTS=0

# ── Debug flags ───────────────────────────────────────────────────────────────
# AUTOTUNE_TELEMETRY_DEBUG=1
